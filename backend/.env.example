APP_NAME=mapping-paris-strava-b2
APP_VERSION=0.1.0
ENV=local
LOG_LEVEL=INFO
API_BASE_URL=http://localhost:8000
STRAVA_CLIENT_ID=
STRAVA_CLIENT_SECRET=
STRAVA_REDIRECT_URI=http://localhost:8000/auth/strava/callback
STRAVA_SCOPES=read,activity:read_all
STRAVA_AUTHORIZE_URL=https://www.strava.com/oauth/authorize
STRAVA_TOKEN_URL=https://www.strava.com/oauth/token
AUTH_STATE_TTL_SECONDS=600
TOKEN_ENCRYPTION_KEY=
DATABASE_URL=sqlite:///./mapping_paris_strava_b2.db
STRAVA_SYNC_PER_PAGE=30
STRAVA_SYNC_MAX_PAGES=1
STRAVA_SYNC_LOAD_MORE_MAX_PAGES=5
STRAVA_SYNC_ABSOLUTE_MAX_PAGES=10
STRAVA_SYNC_DOWNLOAD_STREAMS=true
STRAVA_SYNC_SPORT_TYPES=Run,Ride
STRAVA_TOKEN_REFRESH_MARGIN_SECONDS=300
SEGMENT_DATASET_PATH=../app/src/main/assets/paris_segments.geojson
SEGMENT_DATASET_VERSION=
MATCH_MAX_DISTANCE_METERS=30
MATCH_MIN_COVERAGE_RATIO=0.35
MATCH_MIN_MATCHED_POINTS=2
MATCH_MAX_ACTIVITIES_PER_RUN=20
MATCH_CANDIDATE_BBOX_BUFFER_METERS=50
